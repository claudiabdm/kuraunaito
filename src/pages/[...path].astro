---
import i18next from "i18next";
import { useStoryblokApi } from "@storyblok/astro";
import StoryblokComponent from "@storyblok/astro/StoryblokComponent.astro";
import { generatePathsFromStories, getVersion } from "../utils/functions";
import Layout from "../layouts/Layout.astro";

const path = Astro.params.path;
const paths = await generatePathsFromStories();
const page = paths.find((p) => p.params.path === path);

if (page == null) {
  return Astro.redirect("/404");
}

const { title, lang, slug } = page.props;
const storyblokApi = useStoryblokApi();

i18next.changeLanguage(lang);

const { data } = await storyblokApi.get(
  `cdn/stories/${slug}?language=${i18next.language}`,
  {
    version: getVersion(),
  }
);
const story = data?.story;
---

<Layout {...{ title, slug, seo: story.content.seo }}>
  <StoryblokComponent {...page.props} blok={story?.content} />
</Layout>
